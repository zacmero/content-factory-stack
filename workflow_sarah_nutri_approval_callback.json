    {
      "parameters": {
        "jsCode": "const integrations = $input.all().map((item) => item.json).filter((item) => !item.disabled);\nconst sourceUpload = $node['Upload Source Media'].json || {};\nconst draft = $node['Extract Draft'].json;\nconst pinterestBoardId = '1017461809504351582';\nconst sourceMedia = sourceUpload.id && sourceUpload.path ? [{ id: sourceUpload.id, path: sourceUpload.path }] : [];\nconst generatedMedia = draft.generatedMediaId && draft.generatedMediaPath ? [{ id: draft.generatedMediaId, path: draft.generatedMediaPath }] : [];\nconst media = sourceMedia.length ? sourceMedia : generatedMedia;\nconst mediaSource = sourceMedia.length ? 'source' : generatedMedia.length ? 'generated' : 'none';\nconst posts = [];\nconst postedTo = [];\nconst skipped = [];\n\nfor (const integration of integrations) {\n  const identifier = integration.identifier;\n\n  if (identifier === 'youtube') {\n    posts.push({\n      integration: { id: integration.id },\n      value: [{ content: draft.postText || '', image: media }],\n      settings: {\n        __type: 'youtube',\n        title: (draft.sourceTitle || 'Sarah Nutri Draft').substring(0, 95),\n        type: 'private',\n        tags: [],\n      },\n    });\n    postedTo.push(identifier);\n    continue;\n  }\n\n  if (identifier === 'pinterest') {\n    posts.push({\n      integration: { id: integration.id },\n      value: [{ content: draft.postText || '', image: media }],\n      settings: {\n        __type: 'pinterest',\n        board: pinterestBoardId,\n        title: (draft.sourceTitle || 'Sarah Nutri Draft').substring(0, 95),\n        link: draft.sourceLink || '',\n        dominant_color: '#22c55e',\n      },\n    });\n    postedTo.push(identifier);\n    continue;\n  }\n\n  skipped.push({ integration: identifier, reason: 'No workflow posting template configured yet' });\n}\n\nif (!posts.length) {\n  throw new Error('No eligible Postiz integrations are configured for automatic posting');\n}\n\nconst body = {\n  type: 'draft',\n  shortLink: false,\n  date: new Date().toISOString(),\n  tags: [],\n  posts,\n};\n\nreturn [{ json: { postizBody: JSON.stringify(body), postedTo, skipped, mediaSource } }];"
      },
