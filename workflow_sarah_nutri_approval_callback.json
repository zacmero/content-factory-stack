    {
      "parameters": {
        "jsCode": "const routing = $node['Build Postiz Body'].json;\nconst response = $input.first().json;\nconst postedTo = routing.postedTo || [];\nconst skipped = routing.skipped || [];\nconst mediaSource = routing.mediaSource || 'none';\nconst postedLine = postedTo.length ? `Sent to Postiz draft queue for: ${postedTo.join(', ')}.` : 'No eligible integrations were posted.';\nconst skippedLine = skipped.length ? ` Skipped: ${skipped.map((item) => `${item.integration} (${item.reason})`).join(', ')}.` : '';\nconst mediaLine = mediaSource === 'source' ? ' Used source media.' : mediaSource === 'generated' ? ' Used generated Gemini image fallback.' : ' No media asset was attached.';\nreturn [{ json: { ok: true, action: 'approve', message: postedLine + skippedLine + mediaLine, postedTo, skipped, mediaSource, postizResponse: response } }];"
      },
