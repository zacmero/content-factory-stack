      "parameters": {
        "jsCode": "const candidate = $json.candidates?.[0];\nconst imagePart = candidate?.content?.parts?.find((part) => part.inlineData?.data);\nif (!imagePart) {\n  throw new Error('No inline image data returned by Gemini');\n}\nconst mimeType = imagePart.inlineData.mimeType || 'image/png';\nconst extension = (mimeType.split('/')[1] || 'png').split(';')[0];\nreturn [{\n  json: { mimeType, extension },\n  binary: {\n    image: {\n      data: imagePart.inlineData.data,\n      mimeType,\n      fileName: `generated.${extension}`\n    }\n  }\n}];"
