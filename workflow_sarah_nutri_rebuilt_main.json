            {
              "id": "instruction",
              "name": "instruction",
              "value": "={{ `Write a concise Sarah Nutri social media post for adults and seniors based on this article. Keep it practical, warm, clear, and ready to approve. Return only the final post copy, with no labels, no commentary, and no image prompt. Include 3 to 5 relevant hashtags. Article: ${$node[\"Latest Article\"].json.title || \"\"} - ${$node[\"Latest Article\"].json.contentSnippet || \"\"}` }}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
